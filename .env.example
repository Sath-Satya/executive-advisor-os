# Executive Advisor OS — environment template
# Copy to .env and fill in the key for your preferred model.

# Default model. Any LiteLLM-supported provider works.
# Examples: claude-opus-4-7 | claude-sonnet-4-6 | gpt-4o | gpt-4o-mini | azure/gpt-4o
EAOS_MODEL=claude-opus-4-7

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- OpenAI (optional) ---
OPENAI_API_KEY=

# --- Azure OpenAI (optional) ---
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
